{
  "description": "ECOTRACK — Infrastructure & Docker",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "gridPos": {"h": 2, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {"content": "# 🌿 ECOTRACK — Infrastructure Monitoring\n**5 zones Docker** | node-exporter + cAdvisor | Refresh 30s", "mode": "markdown"},
      "title": "", "type": "text"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}, "unit": "percent", "max": 100, "min": 0}},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 2},
      "id": 2,
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "title": "CPU Usage (%)",
      "type": "gauge",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "100 - (avg(rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)", "legendFormat": "CPU", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}, "unit": "percent", "max": 100, "min": 0}},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 2},
      "id": 3,
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "title": "RAM Usage (%)",
      "type": "gauge",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "RAM", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}, "unit": "percent", "max": 100, "min": 0}},
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 2},
      "id": 4,
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "title": "Disque (%)",
      "type": "gauge",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "(node_filesystem_size_bytes{mountpoint='/',fstype!='tmpfs'} - node_filesystem_free_bytes{mountpoint='/',fstype!='tmpfs'}) / node_filesystem_size_bytes{mountpoint='/',fstype!='tmpfs'} * 100", "legendFormat": "Disque", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "mappings": [{"options": {"0": {"color": "red", "text": "DOWN"}, "1": {"color": "green", "text": "UP"}}, "type": "value"}]}},
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 2},
      "id": 5,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Services actifs",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "count(up == 1)", "legendFormat": "Services UP", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 6,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "CPU par conteneur Docker (%)",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "rate(container_cpu_usage_seconds_total{name=~'eco-.*',name!=''}[5m]) * 100", "legendFormat": "{{name}}", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 7,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Memoire par conteneur Docker",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "container_memory_usage_bytes{name=~'eco-.*',name!=''}", "legendFormat": "{{name}}", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "Bps", "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 5}}},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 8,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Trafic reseau (bytes/s)",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "rate(node_network_receive_bytes_total{device!='lo'}[5m])", "legendFormat": "RX {{device}}", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "rate(node_network_transmit_bytes_total{device!='lo'}[5m])", "legendFormat": "TX {{device}}", "refId": "B"}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ecotrack", "infrastructure"],
  "templating": {
    "list": [{"current": {}, "hide": 0, "label": "Datasource", "name": "datasource", "query": "prometheus", "refresh": 1, "type": "datasource"}]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "Europe/Paris",
  "title": "ECOTRACK — Infrastructure",
  "uid": "ecotrack-infra-v1",
  "version": 1
}
