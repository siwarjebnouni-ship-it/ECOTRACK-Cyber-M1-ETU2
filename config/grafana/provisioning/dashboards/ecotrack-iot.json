{
  "description": "ECOTRACK — IoT & Capteurs 2000 conteneurs",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "gridPos": {"h": 2, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {"content": "# 📡 ECOTRACK — Zone IoT — 2000 Capteurs\n12 zones géographiques · Simulateur actif · Refresh 30s", "mode": "markdown"},
      "title": "", "type": "text"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "mappings": [{"options": {"0": {"color": "red", "text": "DOWN ❌"}, "1": {"color": "green", "text": "UP ✅"}}, "type": "value"}]}},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 2},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "API ECOTRACK",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "up{job='ecotrack-api'}", "legendFormat": "API", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100000000}, {"color": "red", "value": 200000000}]}}},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 2},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Mémoire Simulateur IoT",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "container_memory_usage_bytes{name='eco-simulateur-iot'}", "legendFormat": "RAM IoT", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 80}]}, "max": 100, "min": 0}},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 2},
      "id": 4,
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "title": "CPU Simulateur IoT (%)",
      "type": "gauge",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "rate(container_cpu_usage_seconds_total{name='eco-simulateur-iot',cpu='total'}[5m]) * 100", "legendFormat": "CPU IoT", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 80}]}, "max": 100, "min": 0}},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 2},
      "id": 5,
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "title": "CPU API ECOTRACK (%)",
      "type": "gauge",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "rate(container_cpu_usage_seconds_total{name='eco-api',cpu='total'}[5m]) * 100", "legendFormat": "CPU API", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "Bps", "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}}},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 7},
      "id": 6,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Trafic réseau IoT → API (bytes/s)",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "rate(container_network_receive_bytes_total{name='eco-simulateur-iot'}[5m])", "legendFormat": "IoT RX", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "rate(container_network_transmit_bytes_total{name='eco-simulateur-iot'}[5m])", "legendFormat": "IoT TX", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "rate(container_network_receive_bytes_total{name='eco-api'}[5m])", "legendFormat": "API RX", "refId": "C"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}}},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 16},
      "id": 7,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "title": "Mémoire — Zone IoT & Backend",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "container_memory_usage_bytes{name=~'eco-simulateur-iot|eco-api|eco-redis|eco-postgresql'}", "legendFormat": "{{name}}", "refId": "A"}]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ecotrack", "iot"],
  "templating": {"list": [{"current": {}, "hide": 0, "label": "Datasource", "name": "datasource", "query": "prometheus", "refresh": 1, "type": "datasource"}]},
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "Europe/Paris",
  "title": "ECOTRACK — IoT",
  "uid": "ecotrack-iot-v2",
  "version": 1
}
