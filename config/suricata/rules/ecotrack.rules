# ECOTRACK — Règles Suricata personnalisées

# Règle 1 — Bruteforce SSH
alert tcp any any -> $HOME_NET 22 (msg:"ECOTRACK Bruteforce SSH Detecte"; flow:to_server; threshold:type threshold,track by_src,count 5,seconds 60; sid:1000001; rev:1;)

# Règle 2 — Bruteforce API Login
alert http any any -> $HTTP_SERVERS any (msg:"ECOTRACK Bruteforce API Login"; http.uri; content:"/api/auth/login"; threshold:type threshold,track by_src,count 10,seconds 60; sid:1000002; rev:1;)

# Règle 3 — Scan de ports
alert tcp any any -> $HOME_NET any (msg:"ECOTRACK Scan de Ports Detecte"; flags:S; threshold:type threshold,track by_src,count 10,seconds 5; sid:1000003; rev:1;)

# Règle 4 — Injection SQL
alert http any any -> $HTTP_SERVERS any (msg:"ECOTRACK Injection SQL Detectee"; http.uri; pcre:"/(\bUNION\b|\bSELECT\b|\bDROP\b)/i"; sid:1000004; rev:1;)

# Règle 5 — Trafic IoT anormal
alert tcp 172.20.5.0/24 any -> 172.20.2.0/24 3000 (msg:"ECOTRACK Trafic IoT Anormal"; threshold:type threshold,track by_src,count 100,seconds 60; sid:1000005; rev:1;)